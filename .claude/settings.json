{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "ROOT=$(git rev-parse --show-toplevel) && make -C \"$ROOT\" clean && GBDK_HOME=/home/mathdaman/gbdk make -C \"$ROOT\"",
            "timeout": 120,
            "statusMessage": "Pre-commit build gate: clean build..."
          }
        ]
      }
    ]
  }
}
