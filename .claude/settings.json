{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash -c \"ROOT=$(git rev-parse --show-toplevel) && make -C \\\"$ROOT\\\" clean && make -C \\\"$ROOT\\\"\"",
            "timeout": 120,
            "statusMessage": "Pre-commit build gate: clean build..."
          }
        ]
      }
    ]
  }
}
