      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$ini = 'C:\\Tools\\Emulicious\\Emulicious.ini'; if (Test-Path $ini) { $c = Get-Content $ini; $c = $c -replace '^WindowEmuliciousX=.*','WindowEmuliciousX=100' -replace '^WindowEmuliciousY=.*','WindowEmuliciousY=50' -replace '^WindowDebuggerX=.*','WindowDebuggerX=100' -replace '^WindowDebuggerY=.*','WindowDebuggerY=50' -replace '^WindowDebuggerOpen=.*','WindowDebuggerOpen=false'; Set-Content $ini $c }\"",
            "if": "Bash(java -jar C:\\Tools\\Emulicious\\Emulicious.jar:*)",
            "statusMessage": "Resetting Emulicious window position..."
          }
        ]
      }
    ],
