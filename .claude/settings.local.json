{
  "env": {
    "GBDK_HOME": "C:/gbdk",
    "PYTHONUTF8": "1"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(*)",
      "Grep(*)",
      "Bash(git:*)",
      "Bash(git -*)",
      "Bash(make:*)",
      "Bash(make clean:*)",
      "Bash(make test:*)",
      "Bash(make memory-check:*)",
      "Bash(make bank-post-build:*)",
      "Bash(make build-debug:*)",
      "Bash(make export-sprites:*)",
      "Bash(gh auth:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh push:*)",
      "Bash(py:*)",
      "Bash(py -m:*)",
      "Bash(java -jar C:\\Tools\\Emulicious\\Emulicious.jar:*)",
      "Bash(ls:*)",
      "Bash(ls -:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(head:*)",
      "Bash(awk:*)",
      "Bash(bash -c:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(romusage:*)",
      "Bash(C:\\gbdk\\bin\\romusage:*)",
      "Bash(aseprite:*)",
      "Bash(aseprite --batch:*)",
      "Bash(tiled:*)",
      "Bash(timeout:*)",
      "Bash(gcc:*)",
      "Bash(node:*)",
      "Bash(wc:*)",
      "Bash(kill:*)",
      "Bash(sleep:*)",
      "Bash(sed:*)",
      "Bash(xargs:*)",
      "WebSearch",
      "WebFetch(domain:gbdev.io)",
      "WebFetch(domain:gbdev.gg8.se)",
      "WebFetch(domain:gbdk-2020.github.io)",
      "WebFetch(domain:gbdk.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:emulicious.net)",
      "WebFetch(domain:www.aseprite.org)",
      "WebFetch(domain:doc.mapeditor.org)",
      "WebFetch(domain:docs.pyboy.dk)",
      "WebFetch(domain:superdisk.github.io)",
      "Skill(grill-me)",
      "Skill(executing-plans)",
      "Skill(test)",
      "Skill(build)",
      "Skill(bank-post-build)",
      "Skill(gb-memory-validator)",
      "Skill(bank-pre-write)",
      "Skill(systematic-debugging)",
      "Skill(track-build)",
      "Skill(update-config)",
      "PowerShell(git *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "py C:\\Code\\nuke-raider\\tools\\bank_check_hook.py",
            "statusMessage": "bank-pre-write check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$ini = 'C:\\Tools\\Emulicious\\Emulicious.ini'; if (Test-Path $ini) { $c = Get-Content $ini; $c = $c -replace '^WindowEmuliciousX=.*','WindowEmuliciousX=100' -replace '^WindowEmuliciousY=.*','WindowEmuliciousY=50' -replace '^WindowDebuggerX=.*','WindowDebuggerX=100' -replace '^WindowDebuggerY=.*','WindowDebuggerY=50' -replace '^WindowDebuggerOpen=.*','WindowDebuggerOpen=false'; Set-Content $ini $c }\"",
            "if": "Bash(java -jar C:\\Tools\\Emulicious\\Emulicious.jar:*)",
            "statusMessage": "Resetting Emulicious window position..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py C:\\Code\\nuke-raider\\tools\\post_build_hook.py",
            "statusMessage": "bank-post-build + memory-check..."
          }
        ]
      }
    ]
  }
}
